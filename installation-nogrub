#!/usr/bin/env bash
set -euo pipefail

# ══════════════════════════════════════════════════════════════════════════════
# CONFIG
# ══════════════════════════════════════════════════════════════════════════════
readonly LOCALE="en_US.UTF-8"
readonly HOSTNAME="artix-meta"

USERNAME=""
PW_HASH=""

# ══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════════════════════
die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "==> $*"; }

# ══════════════════════════════════════════════════════════════════════════════
# CLEANUP
# ══════════════════════════════════════════════════════════════════════════════
cleanup() {
  local exit_code=$?
  umount -R /mnt 2>/dev/null || true
  exit $exit_code
}
trap cleanup EXIT

# ══════════════════════════════════════════════════════════════════════════════
# PREREQUISITES
# ══════════════════════════════════════════════════════════════════════════════
check_prerequisites() {
  [[ $EUID -eq 0 ]]                  || die "Must be run as root."
  [[ -d /sys/firmware/efi/efivars ]] || die "Not booted in UEFI mode."
  command -v dialog &>/dev/null      || { info "Installing dialog..."; pacman -Sy --noconfirm dialog; }
  command -v sgdisk &>/dev/null      || { info "Installing gptfdisk..."; pacman -Sy --noconfirm gptfdisk; }
  command -v parted &>/dev/null      || { info "Installing parted..."; pacman -Sy --noconfirm parted; }
}

# ══════════════════════════════════════════════════════════════════════════════
# USER SETUP
# ══════════════════════════════════════════════════════════════════════════════
prompt_username() {
  if [[ -n "$USERNAME" ]]; then
    info "Using provided username: $USERNAME"
    return 0
  fi

  while true; do
    USERNAME=$(dialog --clear --inputbox "Enter username:" 8 40 3>&1 1>&2 2>&3) || { clear; echo "Aborted."; exit 1; }
    [[ -n "$USERNAME" ]] && break
    dialog --msgbox "Username cannot be empty." 6 40
  done
  clear
  info "Username set to: $USERNAME"
}

prompt_password() {
  if [[ -n "$PW_HASH" ]]; then
    info "Using provided password hash"
    return 0
  fi

  local pass1 pass2
  while true; do
    pass1=$(dialog --clear --insecure --passwordbox "Enter password for root and $USERNAME:" 8 50 3>&1 1>&2 2>&3)
    [[ -n "$pass1" ]] || { dialog --msgbox "Password cannot be empty." 6 40; continue; }

    pass2=$(dialog --clear --insecure --passwordbox "Confirm password:" 8 40 3>&1 1>&2 2>&3)
    [[ "$pass1" == "$pass2" ]] && break

    dialog --msgbox "Passwords do not match. Try again." 6 40
  done
  clear
  PW_HASH=$(openssl passwd -6 "$pass1")
  info "Password hash generated"
}

# ══════════════════════════════════════════════════════════════════════════════
# DISK SELECTION
# ══════════════════════════════════════════════════════════════════════════════
select_disk() {
  DISK=""
  while [[ -z "$DISK" ]]; do
    local menu_items=()

    while IFS= read -r dev; do
      local path="/dev/$dev"
      local size model label
      size=$(lsblk  -dno SIZE  "$path" 2>/dev/null)
      model=$(lsblk -dno MODEL "$path" 2>/dev/null | xargs)

      if lsblk -no FSTYPE "$path" 2>/dev/null | grep -qi ntfs; then
        label="[WINDOWS] ${size} ${model}"
      else
        label="${size} ${model}"
      fi
      menu_items+=("$path" "$label")
    done < <(lsblk -dno NAME,RM -e 7,11 | awk '$2 == 0 {print $1}')

    local chosen
    chosen=$(dialog --clear --title "Artix Installer" \
      --menu "Select installation drive: (drives marked [WINDOWS] are blocked)" \
      20 70 10 "${menu_items[@]}" 3>&1 1>&2 2>&3) || { clear; echo "Aborted."; exit 1; }

    if lsblk -no FSTYPE "$chosen" 2>/dev/null | grep -qi ntfs; then
      dialog --msgbox "$chosen contains a Windows installation and cannot be used.\n\nPlease select a different drive." 9 55
    else
      DISK="$chosen"
      [[ "$DISK" =~ [0-9]$ ]] && PART="${DISK}p" || PART="$DISK"
    fi
  done
  clear
}

confirm_install() {
  local disk_info
  disk_info=$(lsblk -o NAME,SIZE,FSTYPE,MOUNTPOINT "$DISK" 2>/dev/null)

  dialog --clear --title "Confirm Installation" \
    --yesno "WARNING: All data on the selected disk will be permanently destroyed.\n\nDisk contents:\n$disk_info\n\nUser:     $USERNAME\nHostname: $HOSTNAME\nLocale:   $LOCALE\n\nProceed with installation?" \
    20 60 || { clear; echo "Aborted."; exit 1; }
  clear
}

# ══════════════════════════════════════════════════════════════════════════════
# PARTITIONING
# ══════════════════════════════════════════════════════════════════════════════
partition_disk() {
  swapoff -a 2>/dev/null || true
  for p in $(lsblk -nlo NAME "$DISK" | tail -n +2); do
    umount -f "/dev/$p" 2>/dev/null || true
  done

  wipefs -af "$DISK"
  sgdisk --zap-all "$DISK"
  parted -a optimal -s "$DISK" \
    mklabel gpt \
    mkpart ESP fat32 1MiB 513MiB \
    set 1 esp on \
    name 1 EFI_SYSTEM \
    mkpart primary ext4 513MiB 131585MiB \
    name 2 ROOT \
    mkpart primary ext4 131585MiB 100% \
    name 3 HOME
}

format_partitions() {
  mkfs.fat -F32 -n EFI_SYSTEM "${PART}1"
  mkfs.ext4 -F  -L root       "${PART}2"
  mkfs.ext4 -F  -L home       "${PART}3"
}

# ══════════════════════════════════════════════════════════════════════════════
# MOUNT
# ══════════════════════════════════════════════════════════════════════════════
mount_partitions() {
  mount -L root /mnt
  mkdir -p /mnt/{boot,home}
  mount -L EFI_SYSTEM /mnt/boot
  mount -L home       /mnt/home
}

# ══════════════════════════════════════════════════════════════════════════════
# BASE INSTALL
# ══════════════════════════════════════════════════════════════════════════════
install_base() {
  basestrap /mnt \
    base base-devel runit elogind-runit \
    linux linux-headers linux-firmware \
    intel-ucode efibootmgr \
    networkmanager networkmanager-runit \
    openssh openssh-runit \
    sudo python git ansible
}

# ══════════════════════════════════════════════════════════════════════════════
# FSTAB
# ══════════════════════════════════════════════════════════════════════════════
generate_fstab() {
  fstabgen -U /mnt >> /mnt/etc/fstab
}

# ══════════════════════════════════════════════════════════════════════════════
# CHROOT CONFIG
# ══════════════════════════════════════════════════════════════════════════════
configure_chroot() {
  artix-chroot /mnt /usr/bin/env \
    USERNAME="$USERNAME" \
    PW_HASH="$PW_HASH" \
    HOSTNAME="$HOSTNAME" \
    LOCALE="$LOCALE" \
    DISK="$DISK" \
    /bin/bash <<'EOF'
set -euo pipefail

# Localization
echo "$LOCALE UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=$LOCALE" > /etc/locale.conf
echo 'KEYMAP=us'    > /etc/vconsole.conf
ln -sf /usr/share/zoneinfo/Europe/Vienna /etc/localtime

# Hostname
echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS

# Services
ln -s /etc/runit/sv/NetworkManager /etc/runit/runsvdir/default/
ln -s /etc/runit/sv/sshd           /etc/runit/runsvdir/default/

# User setup
useradd -m -G wheel -s /bin/bash "$USERNAME"
echo '%wheel ALL=(ALL:ALL) NOPASSWD: ALL' > /etc/sudoers.d/wheel
chmod 0440 /etc/sudoers.d/wheel

printf 'root:%s\n'          "$PW_HASH" | chpasswd -e
printf '%s:%s\n' "$USERNAME" "$PW_HASH" | chpasswd -e

# EFISTUB — clean up stale entries first
while read -r bootnum; do
  efibootmgr -b "$bootnum" -B
done < <(efibootmgr -v | grep "Artix Speed Meta" | grep -oP 'Boot\K[0-9A-Fa-f]{4}')

  ROOT_UUID=$(blkid -s UUID -o value "$(findmnt -n -o SOURCE /)")

  cp /mnt/boot/vmlinuz-linux /mnt/boot/
  cp /mnt/boot/intel-ucode.img /mnt/boot/ 2>/dev/null || true
  cp /mnt/boot/initramfs-linux.img /mnt/boot/

  efibootmgr --create --disk "$DISK" --part 1 --label "Artix Speed Meta" \
      --loader /vmlinuz-linux \
      --unicode "root=UUID=${ROOT_UUID} rw initrd=\intel-ucode.img initrd=\initramfs-linux.img init=/sbin/runit-init quiet loglevel=3 nowatchdog nmi_watchdog=0 rd.luks=0 rd.lvm=0" --verbose

  BOOT_ORDER=$(efibootmgr -v | grep -oP 'Boot\K[0-9A-Fa-f]{4}' | head -1)
  efibootmgr -o "$BOOT_ORDER"

EOF
}

# ══════════════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════════════
main() {
  check_prerequisites

  prompt_username
  prompt_password

  select_disk
  confirm_install

  info "Partitioning $DISK..."
  partition_disk
  partprobe "$DISK" || die "partprobe failed. Partition table may not be updated."

  info "Formatting partitions..."
  format_partitions

  info "Mounting partitions..."
  mount_partitions

  info "Installing base system..."
  install_base

  info "Generating fstab..."
  generate_fstab

  info "Configuring system in chroot..."
  configure_chroot

  show_summary
  prompt_reboot
}

# ══════════════════════════════════════════════════════════════════════════════
# SUMMARY & REBOOT
# ══════════════════════════════════════════════════════════════════════════════
show_summary() {
  local pkg_count
  pkg_count=$(artix-chroot /mnt pacman -Q 2>/dev/null | wc -l)
  clear
  cat <<SUMMARY
══════════════════════════════════════════════════════════════════════════════
  Artix Linux Installation Complete
══════════════════════════════════════════════════════════════════════════════

  Hostname:   $HOSTNAME
  Username:   $USERNAME
  Locale:     $LOCALE
  Packages:   $pkg_count

  Disk:       $DISK
    ${PART}1  EFI_SYSTEM  512M   /boot
    ${PART}2  ROOT        128G   /
    ${PART}3  HOME        rest   /home

  Services:   NetworkManager, sshd
  Bootloader: EFISTUB (linux)

══════════════════════════════════════════════════════════════════════════════
SUMMARY
}

prompt_reboot() {
  echo ""
  read -rp "  Press ENTER to unmount and reboot..."
  info "Unmounting..."
  umount -R /mnt 2>/dev/null || true
  info "Rebooting..."
  reboot
}

main "$@"
