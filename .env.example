# Arch installer configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Any variable left empty will be prompted interactively during install.

# Linux username (lowercase, no spaces)
USERNAME=

# Password — used for root and the user account
PASSWORD=

# Target disk (will be wiped entirely)
# Examples: /dev/nvme0n1  /dev/sda
DISK=

# SSH public key — deployed to ~/.ssh/authorized_keys (leave empty to skip)
SSH_PUBKEY=

# Set to 1 to skip SSH key prompt and install confirmation dialog
NONINTERACTIVE=0
