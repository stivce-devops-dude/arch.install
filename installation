#!/usr/bin/env bash
set -euo pipefail

# ══════════════════════════════════════════════════════════════════════════════
# CONFIG
# ══════════════════════════════════════════════════════════════════════════════
readonly LOCALE="en_US.UTF-8"
readonly HOSTNAME="arch-meta"
readonly TIMEZONE="Europe/Vienna"

USERNAME=""
PASSWORD=""          # plaintext — used to derive PW_HASH + LUKS_PASS; cleared after use
PW_HASH=""
LUKS_PASS=""         # plaintext — cleared after LUKS setup
LUKS_HOME_KEYFILE="" # temp keyfile path — shredded after install
SSH_PUBKEY=""        # optional — deployed to ~/.ssh/authorized_keys
UCODE=""
DISK=""
PART=""

# ══════════════════════════════════════════════════════════════════════════════
# ENV FILE
# ══════════════════════════════════════════════════════════════════════════════
load_env_file() {
  local env_file="${1:-$(dirname "$(realpath "$0")")/.env}"
  [[ -f "$env_file" ]] || return 0
  info "Loading config from $env_file"

  local line key value
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip comments and blank lines
    [[ "$line" =~ ^[[:space:]]*# ]] && continue
    [[ -z "${line// }" ]]           && continue
    # Accept KEY=value or KEY="value" or KEY='value'
    if [[ "$line" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      key="${BASH_REMATCH[1]}"
      value="${BASH_REMATCH[2]}"
      # Strip surrounding quotes
      if [[ "$value" =~ ^\"(.*)\"$ ]] || [[ "$value" =~ ^\'(.*)\'$ ]]; then
        value="${BASH_REMATCH[1]}"
      fi
      printf -v "$key" '%s' "$value"
    fi
  done < "$env_file"
}

# ══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════════════════════
die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "==> $*"; }
step() { echo; echo "──── $* ────"; }

# ══════════════════════════════════════════════════════════════════════════════
# HELPERS
# ══════════════════════════════════════════════════════════════════════════════

# Set PART prefix — NVMe/MMC devices need 'p' before the partition number
set_part_prefix() {
  [[ "$DISK" =~ [0-9]$ ]] && PART="${DISK}p" || PART="$DISK"
}

# Install a package if the command is not already present
ensure_pkg() {
  local cmd="$1" pkg="${2:-$1}"
  command -v "$cmd" &>/dev/null || { info "Installing $pkg..."; pacman -S --noconfirm "$pkg"; }
}

# Returns 0 if the given block device contains an NTFS filesystem
is_windows_disk() {
  lsblk -no FSTYPE "$1" 2>/dev/null | grep -qi ntfs
}

# ══════════════════════════════════════════════════════════════════════════════
# CLEANUP
# ══════════════════════════════════════════════════════════════════════════════
teardown() {
  umount -R /mnt 2>/dev/null || true
  cryptsetup close crypthome 2>/dev/null || true
  cryptsetup close cryptroot 2>/dev/null || true
  [[ -n "$LUKS_HOME_KEYFILE" ]] && shred -u "$LUKS_HOME_KEYFILE" 2>/dev/null || true
}

cleanup() {
  local exit_code=$?
  teardown
  exit $exit_code
}
trap cleanup EXIT
trap 'die "Unexpected failure at line $LINENO — check output above."' ERR

# ══════════════════════════════════════════════════════════════════════════════
# PREREQUISITES
# ══════════════════════════════════════════════════════════════════════════════
check_environment() {
  [[ $EUID -eq 0 ]]                  || die "Must be run as root."
  [[ -d /sys/firmware/efi/efivars ]] || die "Not booted in UEFI mode."
  info "Checking network connectivity..."
  local attempts=5
  for (( i=1; i<=attempts; i++ )); do
    ping -c1 -W5 archlinux.org &>/dev/null && break
    [[ $i -eq $attempts ]] && die "No network connectivity after $attempts attempts."
    info "Network check failed, retrying ($i/$attempts)..."
    sleep 3
  done
}

ensure_tools() {
  sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' /etc/pacman.conf
  pacman -Sy --noconfirm
  ensure_pkg dialog
  ensure_pkg sgdisk   gptfdisk
  ensure_pkg parted
  ensure_pkg openssl
  ensure_pkg cryptsetup
}

detect_ucode() {
  case $(grep -m1 'vendor_id' /proc/cpuinfo) in
    *GenuineIntel*) UCODE="intel-ucode" ;;
    *AuthenticAMD*) UCODE="amd-ucode"   ;;
    *)              UCODE=""            ;;
  esac
  [[ -n "$UCODE" ]] && info "CPU microcode: $UCODE" || info "CPU microcode: none detected"
}

# ══════════════════════════════════════════════════════════════════════════════
# USER INPUT
# ══════════════════════════════════════════════════════════════════════════════
prompt_username() {
  if [[ -n "$USERNAME" ]]; then
    info "Using provided username: $USERNAME"; return 0
  fi

  while true; do
    USERNAME=$(dialog --clear --inputbox "Enter username:" 8 40 3>&1 1>&2 2>&3) \
      || { clear; die "Aborted."; }
    if   [[ -z "$USERNAME" ]];                         then dialog --msgbox "Username cannot be empty." 6 40
    elif [[ "$USERNAME" == "root" ]];                  then dialog --msgbox "'root' is reserved." 6 40
    elif [[ ! "$USERNAME" =~ ^[a-z_][a-z0-9_-]*$ ]]; then dialog --msgbox "Invalid username. Use lowercase letters, numbers, '-' or '_'. Must start with a letter or underscore." 7 60
    else break
    fi
  done
  clear
  info "Username: $USERNAME"
}

prompt_password() {
  if [[ -n "$PASSWORD" ]]; then
    LUKS_PASS="$PASSWORD"
    PW_HASH=$(printf '%s' "$PASSWORD" | openssl passwd -6 -stdin)
    PASSWORD=""
    info "Password hash derived from PASSWORD"; return 0
  fi

  if [[ -n "$PW_HASH" ]]; then
    [[ -n "$LUKS_PASS" ]] || die "LUKS_PASS must be set alongside PW_HASH (needed for disk encryption)."
    info "Using provided password hash"; return 0
  fi

  local pass1 pass2
  while true; do
    pass1=$(dialog --clear --insecure --passwordbox \
      "Enter password for disk encryption, root, and $USERNAME:" 9 60 3>&1 1>&2 2>&3) \
      || { clear; die "Aborted."; }
    [[ -n "$pass1" ]] || { dialog --msgbox "Password cannot be empty." 6 40; continue; }

    pass2=$(dialog --clear --insecure --passwordbox "Confirm password:" 8 40 3>&1 1>&2 2>&3) \
      || { clear; die "Aborted."; }
    [[ "$pass1" == "$pass2" ]] && break
    dialog --msgbox "Passwords do not match. Try again." 6 40
  done
  clear

  LUKS_PASS="$pass1"
  PW_HASH=$(printf '%s' "$pass1" | openssl passwd -6 -stdin)
  info "Password hash generated"
}

prompt_ssh_key() {
  if [[ -n "$SSH_PUBKEY" ]]; then
    info "Using provided SSH public key"; return 0
  fi

  if [[ "${NONINTERACTIVE:-0}" == "1" ]]; then
    info "No SSH public key provided — key-based SSH login will not be available"
    return 0
  fi

  local key
  key=$(dialog --clear --inputbox \
    "Paste your SSH public key (leave empty to skip):" 10 70 3>&1 1>&2 2>&3) \
    || { clear; die "Aborted."; }
  clear

  if [[ -z "$key" ]]; then
    info "No SSH public key provided — key-based SSH login will not be available"
    return 0
  fi

  # Validate key type prefix
  if [[ ! "$key" =~ ^(ssh-rsa|ssh-ed25519|ssh-dss|ecdsa-sha2-nistp256|ecdsa-sha2-nistp384|ecdsa-sha2-nistp521|sk-ssh-ed25519|sk-ecdsa-sha2-nistp256)[[:space:]] ]]; then
    die "Invalid SSH public key format."
  fi

  SSH_PUBKEY="$key"
  info "SSH public key accepted"
}

# ══════════════════════════════════════════════════════════════════════════════
# DISK SELECTION
# ══════════════════════════════════════════════════════════════════════════════

# Outputs alternating "path\nlabel\n" pairs for consumption by dialog --menu
build_disk_menu() {
  while IFS= read -r dev; do
    local path="/dev/$dev" size model label
    size=$(lsblk -dno SIZE "$path" 2>/dev/null) || { echo "WARNING: skipping $path (lsblk failed)" >&2; continue; }
    model=$(lsblk -dno MODEL "$path" 2>/dev/null | xargs)
    is_windows_disk "$path" && label="[WINDOWS] ${size} ${model}" || label="${size} ${model}"
    printf '%s\n%s\n' "$path" "$label"
  done < <(lsblk -dno NAME,RM -e 7,11 | awk '$2 == 0 {print $1}')
}

select_disk() {
  if [[ -n "$DISK" ]]; then
    [[ -b "$DISK" ]]          || die "DISK=$DISK is not a block device."
    ! is_windows_disk "$DISK" || die "DISK=$DISK contains a Windows installation. Refusing to proceed."
    info "Using provided disk: $DISK"
    set_part_prefix; return 0
  fi

  while [[ -z "$DISK" ]]; do
    local -a menu_items
    mapfile -t menu_items < <(build_disk_menu)

    [[ ${#menu_items[@]} -gt 0 ]] || { dialog --msgbox "No suitable disks found." 6 40; clear; exit 1; }

    local chosen
    chosen=$(dialog --clear --title "Arch Installer" \
      --menu "Select installation drive: (drives marked [WINDOWS] are blocked)" \
      20 70 10 "${menu_items[@]}" 3>&1 1>&2 2>&3) || { clear; die "Aborted."; }

    if is_windows_disk "$chosen"; then
      dialog --msgbox "$chosen contains a Windows installation and cannot be used.\n\nPlease select a different drive." 9 55
    else
      DISK="$chosen"
      set_part_prefix
    fi
  done
  clear
}

confirm_install() {
  if [[ "${NONINTERACTIVE:-0}" == "1" ]]; then
    info "Non-interactive mode — skipping confirmation, proceeding with install"
    return 0
  fi

  local disk_info
  disk_info=$(lsblk -o NAME,SIZE,FSTYPE,MOUNTPOINT "$DISK" 2>/dev/null)
  dialog --clear --title "Confirm Installation" \
    --yesno "WARNING: All data on the selected disk will be permanently destroyed.\n\nDisk contents:\n$disk_info\n\nUser:       $USERNAME\nHostname:   $HOSTNAME\nLocale:     $LOCALE\nEncryption: LUKS2 (root + home)\n\nProceed with installation?" \
    22 60 || { clear; die "Aborted."; }
  clear
}

# ══════════════════════════════════════════════════════════════════════════════
# DISK SETUP
# ══════════════════════════════════════════════════════════════════════════════
partition_disk() {
  local disk_mib
  disk_mib=$(( $(lsblk -bdno SIZE "$DISK") / 1024 / 1024 ))
  (( disk_mib >= 131585 )) || die "Disk too small (${disk_mib} MiB); need at least ~128.5 GiB."

  swapoff -a 2>/dev/null || true
  while read -r p; do
    umount -f "/dev/$p" 2>/dev/null || true
  done < <(lsblk -nlo NAME "$DISK" | tail -n +2)

  wipefs -af "$DISK"
  sgdisk --zap-all "$DISK"
  parted -a optimal -s "$DISK" \
    mklabel gpt \
    mkpart ESP fat32 1MiB 513MiB \
    set 1 esp on \
    name 1 EFI_SYSTEM \
    mkpart primary ext4 513MiB 131585MiB \
    name 2 ROOT \
    mkpart primary ext4 131585MiB 100% \
    name 3 HOME
}

encrypt_partitions() {
  info "Encrypting root partition with LUKS2..."
  printf '%s' "$LUKS_PASS" | cryptsetup luksFormat --type luks2 --batch-mode -d - "${PART}2"
  printf '%s' "$LUKS_PASS" | cryptsetup open --type luks2 -d - "${PART}2" cryptroot

  info "Generating home partition keyfile..."
  LUKS_HOME_KEYFILE=$(mktemp)
  dd if=/dev/urandom bs=512 count=4 2>/dev/null > "$LUKS_HOME_KEYFILE"

  info "Encrypting home partition with LUKS2..."
  cryptsetup luksFormat --type luks2 --batch-mode --key-file "$LUKS_HOME_KEYFILE" "${PART}3"
  cryptsetup open --type luks2 --key-file "$LUKS_HOME_KEYFILE" "${PART}3" crypthome

  LUKS_PASS=""
}

format_partitions() {
  mkfs.fat -F32 -n EFI_SYSTEM "${PART}1"
  mkfs.ext4 -F  -L root       /dev/mapper/cryptroot
  mkfs.ext4 -F  -L home       /dev/mapper/crypthome
}

mount_partitions() {
  mount /dev/mapper/cryptroot /mnt
  mkdir -p /mnt/{boot,home}
  mount -L EFI_SYSTEM /mnt/boot
  mount /dev/mapper/crypthome /mnt/home
}

# ══════════════════════════════════════════════════════════════════════════════
# BASE INSTALL
# ══════════════════════════════════════════════════════════════════════════════
install_base() {
  local pkgs=(
    base
    linux linux-firmware
    cryptsetup
    efibootmgr
    openssh
    sudo git neovim
  )
  [[ -n "$UCODE" ]] && pkgs+=("$UCODE")
  pacstrap -K /mnt "${pkgs[@]}"
}

generate_fstab() {
  genfstab -U /mnt > /mnt/etc/fstab
  sed -i 's/\brelatime\b/noatime/g' /mnt/etc/fstab
}

# ══════════════════════════════════════════════════════════════════════════════
# CHROOT CONFIG
# ══════════════════════════════════════════════════════════════════════════════

# Copy files needed inside chroot before entering
stage_chroot_files() {
  printf '%s\n' "$PW_HASH" > /mnt/root/.pwhash
  chmod 600 /mnt/root/.pwhash

  mkdir -p /mnt/etc/luks-keys
  install -m 600 "$LUKS_HOME_KEYFILE" /mnt/etc/luks-keys/home.key
  chmod 700 /mnt/etc/luks-keys
  shred -u "$LUKS_HOME_KEYFILE"
  LUKS_HOME_KEYFILE=""
}

configure_chroot() {
  stage_chroot_files

  local home_uuid
  home_uuid=$(blkid -s UUID -o value "${PART}3")
  [[ -n "$home_uuid" ]] || die "Could not determine home partition UUID."

  arch-chroot /mnt /usr/bin/env \
    USERNAME="$USERNAME" \
    HOSTNAME="$HOSTNAME" \
    LOCALE="$LOCALE" \
    TIMEZONE="$TIMEZONE" \
    DISK="$DISK" \
    PART="$PART" \
    UCODE="$UCODE" \
    HOME_UUID="$home_uuid" \
    SSH_PUBKEY="$SSH_PUBKEY" \
    /bin/bash <<'EOF'
set -euo pipefail
die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "==> $*"; }
trap 'die "Chroot configuration failed at line $LINENO."' ERR

configure_pacman() {
  sed -i '/^#\[multilib\]/,/^#Include/s/^#//' /etc/pacman.conf
  sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' /etc/pacman.conf
  info "Pacman: multilib enabled, parallel downloads = 5"
}

configure_locale() {
  grep -qxF "$LOCALE UTF-8" /etc/locale.gen || echo "$LOCALE UTF-8" >> /etc/locale.gen
  locale-gen
  echo "LANG=$LOCALE" > /etc/locale.conf
  echo 'KEYMAP=us'    > /etc/vconsole.conf
  ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
  hwclock --systohc 2>/dev/null || true
  info "Locale: $LOCALE, timezone: $TIMEZONE"
}

configure_hostname() {
  echo "$HOSTNAME" > /etc/hostname
  cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS
  info "Hostname: $HOSTNAME"
}

configure_encryption() {
  echo "crypthome  UUID=$HOME_UUID  /etc/luks-keys/home.key  luks" >> /etc/crypttab
  sed -i '/^HOOKS=/s/\bfilesystems\b/encrypt filesystems/' /etc/mkinitcpio.conf
  sed -i 's/^#*COMPRESSION=.*/COMPRESSION="zstd"/' /etc/mkinitcpio.conf
  mkinitcpio -p linux
  info "Initramfs rebuilt with encrypt hook and zstd compression"
}

configure_network() {
  cat > /etc/systemd/network/20-wired.network <<NETCONF
[Match]
Name=en*

[Network]
DHCP=yes

[DHCP]
RouteMetric=10
NETCONF

  cat > /etc/systemd/network/25-wireless.network <<NETCONF
[Match]
Name=wl*

[Network]
DHCP=yes

[DHCP]
RouteMetric=20
NETCONF

  ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf 2>/dev/null || true
  info "Network: wired + wireless DHCP configured"
}

configure_ssh() {
  sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
  sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/'              /etc/ssh/sshd_config
  info "SSH: password auth disabled, root login disabled"
}

configure_users() {
  local pw_hash
  pw_hash=$(cat /root/.pwhash)
  shred -u /root/.pwhash

  useradd -m -G wheel -s /bin/bash "$USERNAME"
  echo '%wheel ALL=(ALL:ALL) ALL' > /etc/sudoers.d/wheel
  chmod 0440 /etc/sudoers.d/wheel

  printf 'root:%s\n'           "$pw_hash" | chpasswd -e
  printf '%s:%s\n' "$USERNAME" "$pw_hash" | chpasswd -e

  if [[ -n "$SSH_PUBKEY" ]]; then
    local ssh_dir="/home/$USERNAME/.ssh"
    mkdir -p "$ssh_dir"
    printf '%s\n' "$SSH_PUBKEY" > "$ssh_dir/authorized_keys"
    chmod 700 "$ssh_dir"
    chmod 600 "$ssh_dir/authorized_keys"
    chown -R "$USERNAME:$USERNAME" "$ssh_dir"
    info "SSH: public key deployed for $USERNAME"
  fi

  echo 'umask 027' > /etc/profile.d/umask.sh
  info "Users: root and $USERNAME configured, umask 027 set"
}

configure_services() {
  systemctl enable sshd
  systemctl enable systemd-timesyncd
  systemctl enable systemd-networkd
  systemctl enable systemd-resolved
  systemctl enable fstrim.timer
  info "Services enabled"
}

configure_bootloader() {
  local boot_label="Arch Speed Meta"

  # Remove all stale entries with our label before creating a new one
  while read -r bootnum; do
    efibootmgr -b "$bootnum" -B 2>/dev/null || true
  done < <(efibootmgr -v | grep -F "$boot_label" | grep -oP 'Boot\K[0-9A-Fa-f]{4}')

  local root_uuid ucode_initrd=""
  root_uuid=$(blkid -s UUID -o value "${PART}2")
  [[ -n "$root_uuid" ]] || { echo "ERROR: Could not determine root LUKS partition UUID." >&2; exit 1; }
  [[ -f /boot/initramfs-linux.img ]] || { echo "ERROR: initramfs not found." >&2; exit 1; }
  [[ -n "$UCODE" ]] && ucode_initrd="initrd=\\${UCODE}.img "

  efibootmgr --create --disk "$DISK" --part 1 --label "$boot_label" \
    --loader /vmlinuz-linux \
    --unicode "cryptdevice=UUID=${root_uuid}:cryptroot root=/dev/mapper/cryptroot rw ${ucode_initrd}initrd=\initramfs-linux.img quiet loglevel=3 nowatchdog nmi_watchdog=0 zswap.enabled=0 page_alloc.shuffle=1 rd.lvm=0" \
    --verbose
  info "EFISTUB boot entry created: $boot_label"
}

configure_pacman
configure_locale
configure_hostname
configure_encryption
configure_network
configure_ssh
configure_users
configure_services
configure_bootloader

EOF
}

# ══════════════════════════════════════════════════════════════════════════════
# SUMMARY & REBOOT
# ══════════════════════════════════════════════════════════════════════════════
show_summary() {
  local pkg_count part1_size part2_size part3_size
  pkg_count=$(arch-chroot /mnt pacman -Q 2>/dev/null | wc -l)
  part1_size=$(lsblk -dno SIZE "${PART}1" 2>/dev/null)
  part2_size=$(lsblk -dno SIZE "${PART}2" 2>/dev/null)
  part3_size=$(lsblk -dno SIZE "${PART}3" 2>/dev/null)
  clear
  cat <<SUMMARY
══════════════════════════════════════════════════════════════════════════════
  Arch Linux Installation Complete
══════════════════════════════════════════════════════════════════════════════

  Hostname:   $HOSTNAME
  Username:   $USERNAME
  Locale:     $LOCALE
  Timezone:   $TIMEZONE
  Packages:   $pkg_count

  Disk:       $DISK
    ${PART}1  EFI_SYSTEM  ${part1_size}   /boot      (unencrypted)
    ${PART}2  ROOT        ${part2_size}   /          (LUKS2)
    ${PART}3  HOME        ${part3_size}   /home      (LUKS2, keyfile)

  Services:   sshd, systemd-networkd, systemd-resolved, systemd-timesyncd, fstrim.timer
  Bootloader: EFISTUB (linux)
  Microcode:  ${UCODE:-none}
  Encryption: LUKS2 — enter passphrase at boot

  SSH key:    ${SSH_PUBKEY:+deployed}${SSH_PUBKEY:-not provided — add key to ~/.ssh/authorized_keys before using SSH}

══════════════════════════════════════════════════════════════════════════════
SUMMARY
}

prompt_reboot() {
  echo ""
  read -rp "  Press ENTER to unmount and reboot..."
  teardown
  reboot
}

# ══════════════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════════════
main() {
  load_env_file "${1:-}"

  step "Checking prerequisites"
  check_environment
  ensure_tools
  detect_ucode

  step "Collecting installation parameters"
  prompt_username
  prompt_password
  prompt_ssh_key
  select_disk
  confirm_install

  step "Preparing disk: $DISK"
  partition_disk
  partprobe "$DISK" 2>/dev/null || true
  udevadm settle
  encrypt_partitions
  format_partitions
  mount_partitions

  step "Installing base system"
  install_base
  generate_fstab

  step "Configuring installed system"
  configure_chroot

  show_summary
  prompt_reboot
}

main "$@"
