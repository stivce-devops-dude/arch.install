#!/usr/bin/env bash
set -euo pipefail

# ══════════════════════════════════════════════════════════════════════════════
# CONFIG
# ══════════════════════════════════════════════════════════════════════════════
readonly LOCALE="en_US.UTF-8"
readonly HOSTNAME="arch-meta"
readonly TIMEZONE="Europe/Vienna"

USERNAME=""
PW_HASH=""
LUKS_PASS=""         # plaintext passphrase — cleared after LUKS setup
LUKS_HOME_KEYFILE="" # temp path to home keyfile — shredded after install
UCODE=""
DISK=""
PART=""

# ══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════════════════════
die()  { echo "ERROR: $*" >&2; exit 1; }
info() { echo "==> $*"; }

# ══════════════════════════════════════════════════════════════════════════════
# CLEANUP
# ══════════════════════════════════════════════════════════════════════════════
cleanup() {
  local exit_code=$?
  umount -R /mnt 2>/dev/null || true
  cryptsetup close crypthome 2>/dev/null || true
  cryptsetup close cryptroot 2>/dev/null || true
  [[ -n "$LUKS_HOME_KEYFILE" ]] && shred -u "$LUKS_HOME_KEYFILE" 2>/dev/null || true
  exit $exit_code
}
trap cleanup EXIT

# ══════════════════════════════════════════════════════════════════════════════
# PREREQUISITES
# ══════════════════════════════════════════════════════════════════════════════
check_prerequisites() {
  [[ $EUID -eq 0 ]]                  || die "Must be run as root."
  [[ -d /sys/firmware/efi/efivars ]] || die "Not booted in UEFI mode."

  info "Checking network connectivity..."
  ping -c1 -W5 archlinux.org &>/dev/null || die "No network connectivity. Connect to the internet and try again."

  sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' /etc/pacman.conf

  command -v dialog     &>/dev/null || { info "Installing dialog...";     pacman -Sy --noconfirm dialog;     }
  command -v sgdisk     &>/dev/null || { info "Installing gptfdisk...";   pacman -Sy --noconfirm gptfdisk;   }
  command -v parted     &>/dev/null || { info "Installing parted...";     pacman -Sy --noconfirm parted;     }
  command -v openssl    &>/dev/null || { info "Installing openssl...";    pacman -Sy --noconfirm openssl;    }
  command -v cryptsetup &>/dev/null || { info "Installing cryptsetup..."; pacman -Sy --noconfirm cryptsetup; }

  case $(grep -m1 'vendor_id' /proc/cpuinfo) in
    *GenuineIntel*) UCODE="intel-ucode" ;;
    *AuthenticAMD*) UCODE="amd-ucode"   ;;
    *)              UCODE=""            ;;
  esac
  [[ -n "$UCODE" ]] && info "CPU microcode: $UCODE" || info "CPU microcode: none detected"
}

# ══════════════════════════════════════════════════════════════════════════════
# USER SETUP
# ══════════════════════════════════════════════════════════════════════════════
prompt_username() {
  if [[ -n "$USERNAME" ]]; then
    info "Using provided username: $USERNAME"
    return 0
  fi

  while true; do
    USERNAME=$(dialog --clear --inputbox "Enter username:" 8 40 3>&1 1>&2 2>&3) || { clear; echo "Aborted."; exit 1; }
    if [[ -z "$USERNAME" ]]; then
      dialog --msgbox "Username cannot be empty." 6 40
    elif [[ "$USERNAME" == "root" ]]; then
      dialog --msgbox "'root' is not allowed as a username." 6 45
    elif [[ ! "$USERNAME" =~ ^[a-z_][a-z0-9_-]*$ ]]; then
      dialog --msgbox "Invalid username. Use lowercase letters, numbers, '-' or '_'.\nMust start with a letter or underscore." 7 55
    else
      break
    fi
  done
  clear
  info "Username set to: $USERNAME"
}

prompt_password() {
  if [[ -n "$PW_HASH" ]]; then
    # Non-interactive mode: LUKS_PASS must also be set for disk encryption
    [[ -n "$LUKS_PASS" ]] || die "LUKS_PASS must be set alongside PW_HASH (needed for disk encryption)."
    info "Using provided password hash"
    return 0
  fi

  local pass1 pass2
  while true; do
    pass1=$(dialog --clear --insecure --passwordbox "Enter password for disk encryption, root, and $USERNAME:" 9 60 3>&1 1>&2 2>&3) || { clear; echo "Aborted."; exit 1; }
    [[ -n "$pass1" ]] || { dialog --msgbox "Password cannot be empty." 6 40; continue; }

    pass2=$(dialog --clear --insecure --passwordbox "Confirm password:" 8 40 3>&1 1>&2 2>&3) || { clear; echo "Aborted."; exit 1; }
    [[ "$pass1" == "$pass2" ]] && break

    dialog --msgbox "Passwords do not match. Try again." 6 40
  done
  clear

  LUKS_PASS="$pass1"
  PW_HASH=$(printf '%s' "$pass1" | openssl passwd -6 -stdin)
  info "Password hash generated"
}

# ══════════════════════════════════════════════════════════════════════════════
# DISK SELECTION
# ══════════════════════════════════════════════════════════════════════════════
select_disk() {
  if [[ -n "$DISK" ]]; then
    info "Using provided disk: $DISK"
    [[ "$DISK" =~ [0-9]$ ]] && PART="${DISK}p" || PART="$DISK"
    return 0
  fi

  while [[ -z "$DISK" ]]; do
    local menu_items=()

    while IFS= read -r dev; do
      local path="/dev/$dev"
      local size model label
      size=$(lsblk  -dno SIZE  "$path" 2>/dev/null)
      model=$(lsblk -dno MODEL "$path" 2>/dev/null | xargs)

      if lsblk -no FSTYPE "$path" 2>/dev/null | grep -qi ntfs; then
        label="[WINDOWS] ${size} ${model}"
      else
        label="${size} ${model}"
      fi
      menu_items+=("$path" "$label")
    done < <(lsblk -dno NAME,RM -e 7,11 | awk '$2 == 0 {print $1}')

    [[ ${#menu_items[@]} -eq 0 ]] && { dialog --msgbox "No suitable disks found." 6 40; clear; exit 1; }

    local chosen
    chosen=$(dialog --clear --title "Arch Installer" \
      --menu "Select installation drive: (drives marked [WINDOWS] are blocked)" \
      20 70 10 "${menu_items[@]}" 3>&1 1>&2 2>&3) || { clear; echo "Aborted."; exit 1; }

    if lsblk -no FSTYPE "$chosen" 2>/dev/null | grep -qi ntfs; then
      dialog --msgbox "$chosen contains a Windows installation and cannot be used.\n\nPlease select a different drive." 9 55
    else
      DISK="$chosen"
      [[ "$DISK" =~ [0-9]$ ]] && PART="${DISK}p" || PART="$DISK"
    fi
  done
  clear
}

confirm_install() {
  local disk_info
  disk_info=$(lsblk -o NAME,SIZE,FSTYPE,MOUNTPOINT "$DISK" 2>/dev/null)

  dialog --clear --title "Confirm Installation" \
    --yesno "WARNING: All data on the selected disk will be permanently destroyed.\n\nDisk contents:\n$disk_info\n\nUser:       $USERNAME\nHostname:   $HOSTNAME\nLocale:     $LOCALE\nEncryption: LUKS2 (root + home)\n\nProceed with installation?" \
    22 60 || { clear; echo "Aborted."; exit 1; }
  clear
}

# ══════════════════════════════════════════════════════════════════════════════
# PARTITIONING
# ══════════════════════════════════════════════════════════════════════════════
partition_disk() {
  local disk_mib
  disk_mib=$(( $(lsblk -bdno SIZE "$DISK") / 1024 / 1024 ))
  (( disk_mib >= 131585 )) || die "Disk too small (${disk_mib} MiB); need at least ~128.5 GiB."

  swapoff -a 2>/dev/null || true
  while read -r p; do
    umount -f "/dev/$p" 2>/dev/null || true
  done < <(lsblk -nlo NAME "$DISK" | tail -n +2)

  wipefs -af "$DISK"
  sgdisk --zap-all "$DISK"
  parted -a optimal -s "$DISK" \
    mklabel gpt \
    mkpart ESP fat32 1MiB 513MiB \
    set 1 esp on \
    name 1 EFI_SYSTEM \
    mkpart primary ext4 513MiB 131585MiB \
    name 2 ROOT \
    mkpart primary ext4 131585MiB 100% \
    name 3 HOME
}

encrypt_partitions() {
  info "Encrypting root partition with LUKS2..."
  printf '%s' "$LUKS_PASS" | cryptsetup luksFormat --type luks2 --batch-mode -d - "${PART}2"
  printf '%s' "$LUKS_PASS" | cryptsetup open --type luks2 -d - "${PART}2" cryptroot

  info "Generating home partition keyfile..."
  LUKS_HOME_KEYFILE=$(mktemp)
  dd if=/dev/urandom bs=512 count=4 2>/dev/null > "$LUKS_HOME_KEYFILE"

  info "Encrypting home partition with LUKS2..."
  cryptsetup luksFormat --type luks2 --batch-mode --key-file "$LUKS_HOME_KEYFILE" "${PART}3"
  cryptsetup open --type luks2 --key-file "$LUKS_HOME_KEYFILE" "${PART}3" crypthome

  # Clear plaintext passphrase — no longer needed after this point
  LUKS_PASS=""
  info "Disk encryption configured"
}

format_partitions() {
  mkfs.fat -F32 -n EFI_SYSTEM "${PART}1"
  mkfs.ext4 -F  -L root       /dev/mapper/cryptroot
  mkfs.ext4 -F  -L home       /dev/mapper/crypthome
}

# ══════════════════════════════════════════════════════════════════════════════
# MOUNT
# ══════════════════════════════════════════════════════════════════════════════
mount_partitions() {
  mount /dev/mapper/cryptroot /mnt
  mkdir -p /mnt/{boot,home}
  mount -L EFI_SYSTEM /mnt/boot
  mount /dev/mapper/crypthome /mnt/home
}

# ══════════════════════════════════════════════════════════════════════════════
# BASE INSTALL
# ══════════════════════════════════════════════════════════════════════════════
install_base() {
  local pkgs=(
    base
    linux linux-firmware
    cryptsetup
    efibootmgr
    openssh
    sudo git neovim
  )
  [[ -n "$UCODE" ]] && pkgs+=("$UCODE")
  pacstrap /mnt "${pkgs[@]}"
}

# ══════════════════════════════════════════════════════════════════════════════
# FSTAB
# ══════════════════════════════════════════════════════════════════════════════
generate_fstab() {
  genfstab -U /mnt > /mnt/etc/fstab
  sed -i 's/\brelatime\b/noatime/g' /mnt/etc/fstab
}

# ══════════════════════════════════════════════════════════════════════════════
# CHROOT CONFIG
# ══════════════════════════════════════════════════════════════════════════════
configure_chroot() {
  echo "$PW_HASH" > /mnt/root/.pwhash
  chmod 600 /mnt/root/.pwhash

  # Install home LUKS keyfile onto the target system, then shred the temp copy
  mkdir -p /mnt/etc/luks-keys
  install -m 600 "$LUKS_HOME_KEYFILE" /mnt/etc/luks-keys/home.key
  chmod 700 /mnt/etc/luks-keys
  shred -u "$LUKS_HOME_KEYFILE"
  LUKS_HOME_KEYFILE=""

  local home_uuid
  home_uuid=$(blkid -s UUID -o value "${PART}3")
  [[ -n "$home_uuid" ]] || die "Could not determine home partition UUID."

  arch-chroot /mnt /usr/bin/env \
    USERNAME="$USERNAME" \
    HOSTNAME="$HOSTNAME" \
    LOCALE="$LOCALE" \
    TIMEZONE="$TIMEZONE" \
    DISK="$DISK" \
    PART="$PART" \
    UCODE="$UCODE" \
    HOME_UUID="$home_uuid" \
    /bin/bash <<'EOF'
set -euo pipefail

enable_multilib() {
  sed -i '/^#\[multilib\]/,/^#Include/s/^#//' /etc/pacman.conf
  echo "==> Multilib repository enabled"
}

PW_HASH=$(cat /root/.pwhash)
shred -u /root/.pwhash

# Localization
grep -qxF "$LOCALE UTF-8" /etc/locale.gen || echo "$LOCALE UTF-8" >> /etc/locale.gen
locale-gen

# Enable multilib and parallel downloads
enable_multilib
sed -i 's/^#ParallelDownloads.*/ParallelDownloads = 5/' /etc/pacman.conf
echo "LANG=$LOCALE" > /etc/locale.conf
echo 'KEYMAP=us'    > /etc/vconsole.conf
ln -sf "/usr/share/zoneinfo/$TIMEZONE" /etc/localtime
hwclock --systohc

# Hostname
echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS

# crypttab — unlock home at boot using keyfile stored on the encrypted root
echo "crypthome  UUID=$HOME_UUID  /etc/luks-keys/home.key  luks" >> /etc/crypttab

# mkinitcpio — insert encrypt hook, switch to zstd for faster boot
sed -i '/^HOOKS=/s/\bfilesystems\b/encrypt filesystems/' /etc/mkinitcpio.conf
sed -i 's/^#*COMPRESSION=.*/COMPRESSION="zstd"/' /etc/mkinitcpio.conf
mkinitcpio -P

# Services
systemctl enable sshd
systemctl enable systemd-timesyncd
systemctl enable systemd-networkd
systemctl enable systemd-resolved
systemctl enable fstrim.timer
ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf

# Network — DHCP on wired and wireless
cat > /etc/systemd/network/20-wired.network <<NETCONF
[Match]
Name=en*

[Network]
DHCP=yes

[DHCP]
RouteMetric=10
NETCONF

cat > /etc/systemd/network/25-wireless.network <<NETCONF
[Match]
Name=wl*

[Network]
DHCP=yes

[DHCP]
RouteMetric=20
NETCONF

# SSH hardening — key-based auth only, no root login
sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/'              /etc/ssh/sshd_config

# User setup — sudo requires password
useradd -m -G wheel -s /bin/bash "$USERNAME"
echo '%wheel ALL=(ALL:ALL) ALL' > /etc/sudoers.d/wheel
chmod 0440 /etc/sudoers.d/wheel

printf 'root:%s\n'           "$PW_HASH" | chpasswd -e
printf '%s:%s\n' "$USERNAME" "$PW_HASH" | chpasswd -e

# EFISTUB — clean up stale entries first
while read -r bootnum; do
  efibootmgr -b "$bootnum" -B
done < <(efibootmgr -v | grep "Arch Speed Meta" | grep -oP 'Boot\K[0-9A-Fa-f]{4}')

ROOT_UUID=$(blkid -s UUID -o value "${PART}2")
[[ -n "$ROOT_UUID" ]] || { echo "ERROR: Could not determine root LUKS partition UUID." >&2; exit 1; }

[[ -f /boot/initramfs-linux.img ]] || { echo "ERROR: initramfs not found." >&2; exit 1; }

UCODE_INITRD=""
[[ -n "$UCODE" ]] && UCODE_INITRD="initrd=\\${UCODE}.img "

efibootmgr --create --disk "$DISK" --part 1 --label "Arch Speed Meta" \
    --loader /vmlinuz-linux \
    --unicode "cryptdevice=UUID=${ROOT_UUID}:cryptroot root=/dev/mapper/cryptroot rw ${UCODE_INITRD}initrd=\initramfs-linux.img quiet loglevel=3 nowatchdog nmi_watchdog=0 zswap.enabled=0 page_alloc.shuffle=1 rd.lvm=0" --verbose

EOF
}

# ══════════════════════════════════════════════════════════════════════════════
# SUMMARY & REBOOT
# ══════════════════════════════════════════════════════════════════════════════

show_summary() {
  local pkg_count part1_size part2_size part3_size
  pkg_count=$(arch-chroot /mnt pacman -Q 2>/dev/null | wc -l)
  part1_size=$(lsblk -dno SIZE "${PART}1" 2>/dev/null)
  part2_size=$(lsblk -dno SIZE "${PART}2" 2>/dev/null)
  part3_size=$(lsblk -dno SIZE "${PART}3" 2>/dev/null)
  clear
  cat <<SUMMARY
══════════════════════════════════════════════════════════════════════════════
  Arch Linux Installation Complete
══════════════════════════════════════════════════════════════════════════════

  Hostname:   $HOSTNAME
  Username:   $USERNAME
  Locale:     $LOCALE
  Timezone:   $TIMEZONE
  Packages:   $pkg_count

  Disk:       $DISK
    ${PART}1  EFI_SYSTEM  ${part1_size}   /boot      (unencrypted)
    ${PART}2  ROOT        ${part2_size}   /          (LUKS2)
    ${PART}3  HOME        ${part3_size}   /home      (LUKS2, keyfile)

  Services:   sshd, systemd-networkd, systemd-resolved, systemd-timesyncd, fstrim.timer
  Bootloader: EFISTUB (linux)
  Microcode:  ${UCODE:-none}
  Encryption: LUKS2 — enter passphrase at boot

  NOTE: SSH password authentication is disabled.
        Add your public key to ~/.ssh/authorized_keys before relying on SSH.

══════════════════════════════════════════════════════════════════════════════
SUMMARY
}

prompt_reboot() {
  echo ""
  read -rp "  Press ENTER to unmount and reboot..."
  info "Unmounting..."
  umount -R /mnt 2>/dev/null || true
  cryptsetup close crypthome 2>/dev/null || true
  cryptsetup close cryptroot 2>/dev/null || true
  info "Rebooting..."
  reboot
}

# ══════════════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════════════
main() {
  check_prerequisites

  prompt_username
  prompt_password

  select_disk
  confirm_install

  info "Partitioning $DISK..."
  partition_disk
  partprobe "$DISK" || die "partprobe failed. Partition table may not be updated."

  info "Setting up LUKS2 encryption..."
  encrypt_partitions

  info "Formatting partitions..."
  format_partitions

  info "Mounting partitions..."
  mount_partitions

  info "Installing base system..."
  install_base

  info "Generating fstab..."
  generate_fstab

  info "Configuring system in chroot..."
  configure_chroot

  show_summary
  prompt_reboot
}

main "$@"
